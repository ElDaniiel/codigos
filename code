proc sql;
create table gmc_input1 as 
select distinct 
    a.*,
    b.asegurados_vigentes
from gmc_input as a
left join (
    select 
        año,
        pool,
        sum(
            case 
                when vigor > 0 then vigor
                else vigor2
            end
        ) as asegurados_vigentes
    from gmc_input
    where polvig = 1
    group by año, pool
) as b
on a.año = b.año 
and a.pool = b.pool;
quit;