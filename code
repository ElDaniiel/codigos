proc sort data=gmc_input;
    by pool año fini;
run;

data gmc_input_fix;
    set gmc_input;
    by pool año;

    retain last_vigor;

    /* Reset por grupo */
    if first.pool then last_vigor = .;

    /* Si hay valor válido lo guardo */
    if vigor > 0 then last_vigor = vigor;

    /* Si está en 0, uso el anterior */
    else if vigor = 0 then vigor = last_vigor;

run;code
